---
interface Props {
  eyebrow: string;
  title: string;
  intro: string;
}

const { eyebrow, title, intro } = Astro.props;
---

<section class="page-hero">
  <div class="container page-hero__inner">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p class="lead">{intro}</p>
  </div>
</section>
