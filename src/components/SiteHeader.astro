---
import type { SiteContent } from '../content/site-content';
import { property } from '../data/property';
import { localizedPath, type Locale, type PageSlug } from '../lib/i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  locale: Locale;
  page: PageSlug;
  content: SiteContent;
}

const { locale, page, content } = Astro.props;

const navItems: Array<{ slug: PageSlug; label: string }> = [
  { slug: '', label: content.navigation.home },
  { slug: 'accommodation', label: content.navigation.accommodation },
  { slug: 'gallery', label: content.navigation.gallery },
  { slug: 'location', label: content.navigation.location },
  { slug: 'availability', label: content.navigation.availability },
  { slug: 'contact', label: content.navigation.contact }
];
---

<header class="site-header">
  <div class="container site-header__inner">
    <div class="topbar__inner">
      <p class="topbar__text">{content.metadata.announcement}</p>
      <LanguageSwitcher locale={locale} page={page} />
    </div>
    <div class="header-main">
      <a href={localizedPath(locale)} class="brand">
        <span class="brand__mark">HP</span>
        <span class="brand__copy">
          <strong>{property.siteName}</strong>
          <small>{content.footer.tagline}</small>
        </span>
      </a>

      <nav class="site-nav">
        <div class="site-nav__scroller">
          {
            navItems.map((item) => (
              <a
                href={localizedPath(locale, item.slug)}
                class:list={['site-nav__link', item.slug === page && 'is-active']}
                aria-current={item.slug === page ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))
          }
        </div>
      </nav>

      <div class="header-actions">
        <a class="button button--ghost" href={`https://wa.me/${property.whatsappE164.replace('+', '')}`}>
          {content.common.secondaryCta}
        </a>
        <a class="button" href={localizedPath(locale, 'contact')}>
          {content.common.primaryCta}
        </a>
      </div>
    </div>
  </div>
</header>
