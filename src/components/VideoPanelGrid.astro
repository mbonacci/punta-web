---
import type { AtmosphereVideoItem } from '../content/site-content';
import type { GalleryMediaItem } from '../data/property';
import MediaAsset from './MediaAsset.astro';

type VideoPanelItem = AtmosphereVideoItem;

interface Props {
  items: VideoPanelItem[];
}

const { items } = Astro.props;

function toMediaItem(item: VideoPanelItem, index: number): GalleryMediaItem {
  if (item.embedUrl) {
    return {
      id: `atmosphere-${index}`,
      type: 'video',
      source: 'embed',
      embedUrl: item.embedUrl,
      poster: item.poster
    };
  }

  return {
    id: `atmosphere-${index}`,
    type: 'video',
    source: 'file',
    src: item.src!,
    poster: item.poster,
    autoplay: item.autoplay,
    loop: item.loop,
    muted: item.muted
  };
}
---

<div class="video-panel-grid">
  {
    items.map((item, index) => (
      <article class="card card--video video-panel-grid__item">
        <MediaAsset
          item={toMediaItem(item, index)}
          alt={item.title}
          class:list={[
            'video-panel__media',
            item.embedUrl ? 'video-panel__media--embed' : 'video-panel__media--file'
          ]}
          controls={!item.embedUrl}
        />
        <h3>{item.title}</h3>
        <p>{item.text}</p>
      </article>
    ))
  }
</div>
