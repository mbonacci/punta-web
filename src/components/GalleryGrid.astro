---
import type { SiteContent } from '../content/site-content';
import { galleryMedia, type GalleryMediaItem } from '../data/property';
import MediaAsset from './MediaAsset.astro';

interface Props {
  content: SiteContent;
  limit?: number;
}

const { content, limit } = Astro.props;
const items = typeof limit === 'number' ? galleryMedia.slice(0, limit) : galleryMedia;

type TileVariant = 'featured' | 'wide' | 'standard' | 'tall';

function getAspectRatio(item: GalleryMediaItem) {
  if (!item.width || !item.height) {
    return undefined;
  }

  return item.width / item.height;
}

function createTileVariants(mediaItems: GalleryMediaItem[]) {
  let landscapeCount = 0;

  return mediaItems.map((item, index) => {
    const ratio = getAspectRatio(item);

    if (ratio === undefined) {
      return index === 0 ? 'featured' : 'standard';
    }

    if (ratio < 0.82) {
      return 'tall';
    }

    if (ratio >= 1.25) {
      let variant: TileVariant;

      if (landscapeCount === 0) {
        variant = 'featured';
      } else if (landscapeCount === 1 || landscapeCount % 2 === 1) {
        variant = 'wide';
      } else {
        variant = 'standard';
      }

      landscapeCount += 1;
      return variant;
    }

    return 'standard';
  });
}

const tileVariants = createTileVariants(items);
---

<div class="gallery-grid">
  {
    items.map((item, index) => (
      <article
        class:list={[
          'gallery-card',
          `gallery-card--${tileVariants[index]}`,
          item.type === 'video' && 'gallery-card--video'
        ]}
      >
        <MediaAsset
          item={item}
          alt={content.galleryCaptions[item.id]}
          class="gallery-card__media"
          fill={true}
          loading={item.priority ? 'eager' : 'lazy'}
          fetchpriority={item.priority ? 'high' : 'auto'}
        />
      </article>
    ))
  }
</div>
