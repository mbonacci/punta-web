---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { getSiteContent } from '../../content/site-content';
import { getStaticLocalePaths, type Locale } from '../../lib/i18n';

export function getStaticPaths() {
  return getStaticLocalePaths();
}

const locale = Astro.params.locale as Locale;
const content = getSiteContent(locale);
---

<BaseLayout locale={locale} page="privacy" content={content}>
  <PageHero
    eyebrow={content.privacy.hero.eyebrow}
    title={content.privacy.hero.title}
    intro={content.privacy.hero.intro}
  />

  <section class="section">
    <div class="container legal-layout">
      <p class="lead lead--compact">{content.privacy.introduction}</p>
      {
        content.privacy.sections.map((section) => (
          <article class="legal-card">
            <h2>{section.title}</h2>
            {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          </article>
        ))
      }
      <article class="legal-card legal-card--soft">
        <p>{content.privacy.closing}</p>
      </article>
    </div>
  </section>
</BaseLayout>
